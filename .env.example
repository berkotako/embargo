# Copy to `.env` for compose.prod.yml:  cp .env.example .env
# Never commit the resulting .env (it is gitignored).

# Released image tag to pull from GHCR (the version you deployed).
EMBARGO_VERSION=0.1.0

# Hostname to advertise in quickstart output (informational).
EMBARGO_HOST=localhost

# --- Postgres (engine state) ---
POSTGRES_DB=embargo
POSTGRES_USER=postgres
# REQUIRED: set a strong password.
POSTGRES_PASSWORD=change-me

# --- Auth ---
# `dev` = role picker (evaluation). Set to `oidc` for production and fill the
# rest in. (The console image must also be built with VITE_AUTH_MODE=oidc; the
# published console ships `dev` — see DEPLOYMENT.md.)
EMBARGO__AUTH__MODE=dev
EMBARGO__AUTH__ISSUER=
EMBARGO__AUTH__AUDIENCE=
EMBARGO__AUTH__JWKS_URL=
