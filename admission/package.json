{
  "name": "@embargo/admission",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Embargo L2 Admission Control — CI lockfile-diff gate that calls the engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "embargo-admit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts test/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
