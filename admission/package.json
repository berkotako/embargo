{
  "name": "@embargo/admission",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Embargo L2 Admission Control — CI lockfile-diff gate that calls the engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "embargo-admit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts test/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.8.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
