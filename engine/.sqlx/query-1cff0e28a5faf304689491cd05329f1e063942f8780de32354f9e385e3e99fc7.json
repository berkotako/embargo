  "query": "\n        SELECT package, version, verdict, reasons, signals, provenance, computed_at, expires_at\n        FROM verdicts\n        WHERE verdict = $1\n        ORDER BY computed_at DESC\n        LIMIT $2 OFFSET $3\n        ",
