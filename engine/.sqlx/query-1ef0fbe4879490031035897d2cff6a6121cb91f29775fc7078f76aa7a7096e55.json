{
  "db_name": "PostgreSQL",
  "query": "\n        UPDATE approvals\n        SET status = 'active',\n            approver_id = $2,\n            expires_at = NOW() + make_interval(hours => COALESCE(ttl_hours, 24)::int)\n        WHERE id = $1\n          AND status = 'pending'\n          AND requester_id <> $2\n        RETURNING id, package, version, requester_id, approver_id, justification, expires_at, created_at\n        ",
