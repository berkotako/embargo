  "db_name": "PostgreSQL",
  "query": "\n        SELECT package, version, source, ecosystem, synced_at\n        FROM known_malicious\n        WHERE ($1::text IS NULL OR package ILIKE $1)\n        ORDER BY synced_at DESC, package ASC\n        LIMIT $2 OFFSET $3\n        ",
