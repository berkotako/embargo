{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, package, version, requester_id, approver_id, justification, expires_at, status, created_at\n        FROM approvals\n        WHERE package = $1\n          AND version = $2\n          AND status = 'active'\n          AND expires_at > NOW()\n        LIMIT 1\n        ",
